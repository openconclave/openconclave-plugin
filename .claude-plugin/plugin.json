{
  "name": "openconclave",
  "version": "0.1.0",
  "description": "AI agent orchestration with visual workflow automation. Claude Code + Ollama engines, channel-in-the-loop, workflows-as-MCP-tools.",
  "author": {
    "name": "OpenConclave"
  },
  "license": "MIT",
  "keywords": ["workflow", "orchestration", "agents", "ollama", "mcp", "automation"],
  "mcpServers": {
    "openconclave": {
      "command": "bun",
      "args": ["run", "${HOME}/.openconclave-app/packages/server/src/mcp/server.ts"],
      "cwd": "${HOME}/.openconclave-app"
    },
    "openconclave-channel": {
      "command": "bun",
      "args": ["run", "${HOME}/.openconclave-app/packages/server/src/channel/openconclave-channel.ts"],
      "cwd": "${HOME}/.openconclave-app"
    }
  },
  "channels": [
    {
      "server": "openconclave-channel"
    }
  ]
}
